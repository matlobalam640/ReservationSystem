APP_NAME="HERO Reservation System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/ReservationSystem

# Production (Hostinger / HTTPS) — required for login to work:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-domain.hostingersite.com
# SESSION_SECURE_COOKIE=true
# Run after deploy:
#   php artisan key:generate
#   php artisan migrate --force
#   php artisan livewire:publish --assets
#   php artisan route:clear
#   php artisan config:clear
#   php artisan cache:clear
# Do NOT use route:cache on shared hosting unless Livewire routes are verified.

DB_CONNECTION=sqlite
# Production (XAMPP MySQL): uncomment below and create database `hero_reservations`
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=hero_reservations
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set true on HTTPS production (Hostinger):
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
